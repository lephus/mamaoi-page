# Copy sang .env.local roi dien gia tri that.

# --- Brevo: contacts (REST API) ---
BREVO_API_KEY=
BREVO_LIST_EVENT=3
BREVO_LIST_WAITLIST=4

# --- Brevo: gui email (SMTP relay). Tai khoan phai duoc kich hoat gui email. ---
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=       # SMTP login (dang xxx@smtp-brevo.com)
BREVO_SMTP_KEY=         # SMTP key (xsmtpsib-...)
BREVO_SENDER_EMAIL=     # sender da verify trong Brevo
BREVO_SENDER_NAME=Mama Oi

# --- Google Sheets (bo trong = tat mirror) ---
GOOGLE_SHEET_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# --- reCAPTCHA (bo trong = chi dung honeypot) ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# --- Analytics ---
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
