# Copy sang .env.local roi dien gia tri that.

# --- Brevo: contacts (REST API) ---
BREVO_API_KEY=
BREVO_LIST_EVENT=3
BREVO_LIST_WAITLIST=4

# --- Brevo: gui email (SMTP relay). Tai khoan phai duoc kich hoat gui email. ---
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=       # SMTP login (dang xxx@smtp-brevo.com)
BREVO_SMTP_KEY=         # SMTP key (xsmtpsib-...)
BREVO_SENDER_EMAIL=     # sender da verify trong Brevo
BREVO_SENDER_NAME=Mama Oi

# --- Analytics ---
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# --- Google Sheets: ban ghi tho cho ops (bo trong = bo qua hoan toan) ---
# Service account phai duoc share Sheet voi quyen Editor, neu khong moi lan
# append tra ve 403.
GOOGLE_SHEET_ID=                # ID nam trong URL cua Sheet
GOOGLE_CLIENT_EMAIL=            # vd: xxx@yyy.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=             # private key PEM, giu nguyen \n

# --- Supabase (kho dang ky + trang thai check-in) ---
SUPABASE_URL=https://ynebuselhjttlvbfpklb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=      # service role key (chi dung server-side, KHONG bao gio de lo ra client)

# --- Admin (/admin) ---
ADMIN_EMAIL=                    # email dang nhap admin, vd: admin@digitalunicorn.fr
ADMIN_PASSWORD=                 # mat khau admin
ADMIN_SESSION_SECRET=           # chuoi ngau nhien ky cookie phien: openssl rand -base64 32

# --- Base URL cho QR / duong dan check-in (tuy chon, mac dinh https://mamaoi.vn) ---
NEXT_PUBLIC_SITE_URL=https://mamaoi.vn
